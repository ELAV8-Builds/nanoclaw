# Dependencies
node_modules/
.npm-cache/

# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups — track CLAUDE.md for every agent, ignore runtime artifacts
groups/*/logs/
groups/*/conversations/
groups/*/skills/

# Main group: track CLAUDE.md + sovereign-skills, ignore Bizo build artifacts
groups/main/*
!groups/main/CLAUDE.md
!groups/main/sovereign-skills/

# Secrets
*.keys.json
.env
.envexport

# OS
.DS_Store

# IDE
.idea/
.vscode/
.claude/

# Skills system (local per-installation state)
.nanoclaw/

# SDK docs cache
agents-sdk-docs

# Backup files
*.bak
